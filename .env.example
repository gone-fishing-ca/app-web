# API base — the FastAPI service in ../api
NEXT_PUBLIC_API_BASE=http://localhost:8787

# Supabase Auth — Settings → API → Project URL + API Keys (new "Publishable").
# The publishable key carries the same low privileges as the legacy anon key
# and is safe to ship to the browser. Never put DATABASE_URL / sb_secret_*
# here — those are server-side only.
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
